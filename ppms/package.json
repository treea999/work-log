    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "bcryptjs": "3.0.3",
    "html2canvas": "1.4.1",
    "jsonwebtoken": "9.0.3",
    "jspdf": "4.2.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "prisma": "7.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "2.6.0",
    "recharts": "3.10.0",
    "xlsx": "0.18.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "4.23.1",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.19"
  }
