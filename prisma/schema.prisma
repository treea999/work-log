generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  Draft
  Pending_Approval
  Approved
  In_Progress
  Suspended
  Delayed
  Completed
  Cancelled
  Closed
}

enum ApprovalStatus {
  Draft
  Pending
  Approved
  Rejected
  Returned
  Cancelled
}

enum PaymentStatus {
  Unpaid
  Paid
  Partial
}

enum UserRole {
  Admin
  PM
  Finance
  Member
  Approver
  Auditor
}

enum TimesheetStatus {
  draft
  submitted
  approved
  locked
  rejected
}

enum BudgetStatus {
  draft
  pending_review
  approved
  active
  rejected
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String   @unique
  password  String
  role      UserRole @default(Member)
  department String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managedProjects  Project[]   @relation("ProjectManager")
  assignedProjects ProjectMember[]
  expenses         Expense[]
  approvals        Approval[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  timesheets       Timesheet[] @relation("TimesheetEmployee")
  budgetsCreated   Budget[] @relation("BudgetCreator")
  budgetsReviewed  Budget[] @relation("BudgetReviewer")

  @@map("users")
}

model Project {
  id        String        @id @default(cuid())
  code      String        @unique
  name      String
  description String?
  objective String?
  type      String?
  department String
  sponsor   String?
  managerId String
  manager   User          @relation("ProjectManager", fields: [managerId], references: [id])
  secrecy   String        @default("Normal")
  location  String?
  startDate DateTime
  endDate   DateTime
  priority  String        @default("Medium")
  status    ProjectStatus @default(Draft)
  progress  Int           @default(0)
  healthScore Int         @default(100)
  riskLevel String        @default("Low")
  budget    Float         @default(0)
  fiscalYear String?
  budgetSource String?
  budgetType String?
  capitalBudget  Float    @default(0)
  operatingBudget Float  @default(0)
  personnelBudget Float  @default(0)
  procurementBudget Float @default(0)
  travelBudget Float     @default(0)
  reserveBudget Float    @default(0)
  budgetNotes String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  createdBy String

  members      ProjectMember[]
  expenses     Expense[]
  workItems    WorkItem[]
  risks        Risk[]
  approvals    Approval[]
  auditLogs    AuditLog[]
  notifications Notification[]
  timesheets    Timesheet[] @relation("TimesheetProject")
  timesheetEntries TimesheetEntry[] @relation("TimesheetEntryProject")
  budgets       Budget[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Expense {
  id             String         @id @default(cuid())
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category       String?
  date           DateTime?
  type           String?
  vendor         String?
  description    String?
  amountExclTax  Float          @default(0)
  tax            Float          @default(0)
  amountInclTax  Float          @default(0)
  invoiceNo      String?
  poNo           String?
  requesterId    String?
  requester      User?          @relation(fields: [requesterId], references: [id])
  approverId     String?
  approvalStatus ApprovalStatus @default(Pending)
  paymentStatus  PaymentStatus  @default(Unpaid)
  attachments    Json           @default("[]")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("expenses")
}

model WorkItem {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  type        String   @default("Task")
  name        String
  description String?
  assigneeId  String?
  startDate   DateTime?
  endDate     DateTime?
  duration    Int?
  status      String   @default("To Start")
  progress    Int      @default(0)
  priority    String   @default("Medium")
  dependsOn   Json     @default("[]")
  relatedTo   Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("work_items")
}

model Risk {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description      String
  impact           String   @default("Medium")
  probability      String   @default("Medium")
  severity         String   @default("Medium")
  ownerId          String?
  preventionPlan   String?
  mitigationPlan   String?
  expectedCloseDate DateTime?
  status           String   @default("Open")
  createdAt        DateTime @default(now())

  @@map("risks")
}

model Approval {
  id          String         @id @default(cuid())
  type        String
  refId       String
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id])
  requesterId String
  requester   User           @relation(fields: [requesterId], references: [id])
  amount      Float          @default(0)
  status      ApprovalStatus @default(Pending)
  comments    Json           @default("[]")
  workflow    Json           @default("[]")
  currentStep Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("approvals")
}

model AuditLog {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  comment   String?
  entityType String?
  entityId   String?
  actorRole  String?
  metadata   Json?
  timestamp DateTime @default(now())

  @@index([entityType, entityId])

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  message   String
  refId     String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Timesheet {
  id              String          @id @default(cuid())
  employeeId      String
  employee        User            @relation("TimesheetEmployee", fields: [employeeId], references: [id])
  projectId       String?
  project         Project?        @relation("TimesheetProject", fields: [projectId], references: [id])
  weekStart       DateTime
  weekEnd         DateTime
  status          TimesheetStatus @default(draft)
  submittedAt     DateTime?
  approvedAt      DateTime?
  lockedAt        DateTime?
  rejectedReason  String?
  entries         TimesheetEntry[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, weekStart, weekEnd])
  @@index([projectId, status])
  @@map("timesheets")
}

model TimesheetEntry {
  id          String    @id @default(cuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?  @relation("TimesheetEntryProject", fields: [projectId], references: [id])
  workDate    DateTime
  hours       Float
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([timesheetId])
  @@map("timesheet_entries")
}

model Budget {
  id                String       @id @default(cuid())
  projectId         String?
  project           Project?     @relation(fields: [projectId], references: [id])
  fiscalYear        String
  name              String
  totalAmount       Float
  capitalAmount     Float        @default(0)
  operatingAmount   Float        @default(0)
  personnelAmount   Float        @default(0)
  procurementAmount Float        @default(0)
  travelAmount      Float        @default(0)
  reserveAmount     Float        @default(0)
  notes             String?
  status            BudgetStatus @default(draft)
  rejectionReason   String?
  createdById       String
  createdBy         User         @relation("BudgetCreator", fields: [createdById], references: [id])
  reviewedById      String?
  reviewedBy        User?        @relation("BudgetReviewer", fields: [reviewedById], references: [id])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([projectId, status])
  @@map("budgets")
}

